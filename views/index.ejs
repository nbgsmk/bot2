<!DOCTYPE html>
<html>
  <head>
    <title><%= title %></title>
    <link rel='stylesheet' href='/stylesheets/style.css' />
  </head>
  <body>
    <h1><%= title %></h1>
    <p>History of BTC and ETH prices, volume, and trade count (window: <%= windowSize %>, updated every <%= intervalMinutes %> minutes)</p>
    
    <% if (history && history.length > 0) { %>
      <table border="1" cellpadding="10" style="border-collapse: collapse; width: 100%;">
        <thead>
          <tr>
            <th>Timestamp</th>
            <th>BTC Price (USDT)</th>
            <th>BTC Vol (<%= windowSize %>)</th>
            <th>BTC Trades</th>
            <th>ETH Price (USDT)</th>
            <th>ETH Vol (<%= windowSize %>)</th>
            <th>ETH Trades</th>
          </tr>
        </thead>
        <tbody>
          <% [...history].reverse().forEach(function(entry) { %>
            <tr>
              <td><%= entry.timestamp %></td>
              <td><%= Number(entry.btcPrice).toFixed(displayDecimals) %></td>
              <td><%= Number(entry.btcVolume).toFixed(displayDecimals) %></td>
              <td><%= entry.btcTrades %></td>
              <td><%= Number(entry.ethPrice).toFixed(displayDecimals) %></td>
              <td><%= Number(entry.ethVolume).toFixed(displayDecimals) %></td>
              <td><%= entry.ethTrades %></td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    <% } else { %>
      <p>No data stored yet. Please wait for the first fetch or refresh the page.</p>
    <% } %>
  </body>
</html>
