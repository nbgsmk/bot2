<!DOCTYPE html>
<html>
  <head>
    <title><%= title %></title>
    <link rel='stylesheet' href='/stylesheets/style.css' />
  </head>
  <body>
    <h1><%= title %></h1>
    <p>History of BTC and ETH prices, volume, and trade count (window: <%= windowSize %>, updated every <%= intervalMinutes %> minutes)</p>

    <!-- table header -->
    <% if (history && history.length > 0) { %>
      <table border="1" cellpadding="10" style="border-collapse: collapse; width: 100%;">
        <thead>
          <tr>
            <th>Timestamp</th>
            <th>BTC Price (USDT)</th>
            <th>BTC Vol (<%= windowSize %>)</th>
            <th>BTC Num Trades</th>
            <th>ETH Price (USDT)</th>
            <th>ETH Vol (<%= windowSize %>)</th>
            <th>ETH Num Trades</th>
          </tr>
        </thead>

          <!-- table body -->
        <tbody>
          <% [...history].reverse().forEach(function(entry) { %>
            <tr>
              <td><%= entry.timestamp %></td>
              <td><%= Number(entry.btc_close).toFixed(displayDecimals) %></td>
              <td><%= Number(entry.btc_volume).toFixed(displayDecimals) %></td>
              <td><%= entry.btc_tradeCount %></td>
              <td><%= Number(entry.eth_close).toFixed(displayDecimals) %></td>
              <td><%= Number(entry.eth_volume).toFixed(displayDecimals) %></td>
              <td><%= entry.eth_tradeCount %></td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    <% } else { %>
      <p>No data stored yet. Please wait for the first fetch or refresh the page.</p>
    <% } %>
  </body>
</html>
