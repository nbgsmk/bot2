<!DOCTYPE html>
<html>
  <head>
    <title><%= title %></title>
    <link rel='stylesheet' href='/stylesheets/style.css' />
  </head>
  <body>
    <h1><%= title %></h1>
    <p>History of BTC and ETH prices, volume, and trade count (window: <%= windowSize %>, updated every <%= intervalMinutes %> minutes)</p>

    <!-- table header -->
    <% if (history && history.length > 0) { %>
      <table border="1" cellpadding="10" style="border-collapse: collapse; width: 100%;">
        <thead>
          <tr>
            <th>Timestamp</th>
            <% symbols.forEach(function(s) { %>
              <th><%= s.replace('USDT', '') %> Price (USDT)</th>
              <th><%= s.replace('USDT', '') %> Vol (<%= windowSize %>)</th>
              <th><%= s.replace('USDT', '') %> Num Trades</th>
            <% }); %>
          </tr>
        </thead>

          <!-- table body -->
        <tbody>
          <% [...history].reverse().forEach(function(entry) { %>
            <tr>
              <td><%= entry.timestamp %></td>
              <% symbols.forEach(function(s) { %>
                <% const data = entry[s]; %>
                <% if (data && typeof data === 'object' && !Array.isArray(data)) { %>
                  <td><%= Number(data.close).toFixed(displayDecimals) %></td>
                  <td><%= Number(data.tradeVolume).toFixed(displayDecimals) %></td>
                  <td><%= data.tradeCount %></td>
                <% } else if (data && Array.isArray(data)) { %>
                  <td><%= Number(data[3]).toFixed(displayDecimals) %></td>
                  <td><%= Number(data[5]).toFixed(displayDecimals) %></td>
                  <td><%= data[6] %></td>
                <% } else { %>
                  <td colspan="3" style="text-align: center; color: #999;">Structure changed</td>
                <% } %>
              <% }); %>
            </tr>
          <% }); %>
        </tbody>
      </table>
    <% } else { %>
      <p>No data stored yet. Please wait for the first fetch or refresh the page.</p>
    <% } %>
  </body>
</html>
